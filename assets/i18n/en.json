  "onboarding.slide1_title": "The Tengri belief",
  "onboarding.slide1_subtitle": "For ancient Turks and Mongols, nature and the sky were sacred. Trees were seen as a link between the sky and people.",
  "onboarding.slide2_title": "Tying a cloth to a tree",
  "onboarding.slide2_subtitle": "People tied cloths to sacred trees, believing they were connecting with nature and spirits. The tradition travelled from Central Asia to today.",
  "onboarding.slide3_title": "Tie a Chaput to a tree",
  "onboarding.slide3_subtitle": "People leave a one-line Chaput on each other’s profile. If the other person replies, it turns into a conversation.",
  "onboarding.slide4_title": "A bit more crowded than DMs",
  "onboarding.slide4_subtitle": "Conversations on Chaput are not hidden. People can read chats and like other people’s messages.",
  "onboarding.slide5_title": "Know people by how they talk",
  "onboarding.slide5_subtitle": "Profile photos can mislead. The way people talk to others usually says more.",
  "onboarding.slide6_title": "Whisper",
  "onboarding.slide6_subtitle": "If you whisper, only you and the tree owner can see the message.",
  "onboarding.slide7_title": "Not everyone has to see everything",
  "onboarding.slide7_subtitle": "If you tie a hidden Chaput, only the tree owner can see who you are.",
  "onboarding.slide8_title": "You can read quietly",
  "onboarding.slide8_subtitle": "Some chats get oddly interesting. You come back just to see if there is more."
}
